<odoo>
  <data>

      <!--CRM LEAD LIST VIEW -->
      <record id="view_crm_lead_tree_inherit" model="ir.ui.view">
          <field name="name">crm.lead.tree.inherit</field>
          <field name="model">crm.lead</field>
          <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
          <field name="arch" type="xml">
              <xpath expr="//field[@name='name']" position="before">
                  <field name="tokan_number"/>
              </xpath>

          </field>
      </record>


      <!--CRM LEAD FORM VIEW -->
      <record id="crm_lead_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

<!--            <xpath expr="//div[contains(@class, 'oe_button_box')]" position="after">-->
<!--                <div class="oe_title">-->
<!--                    <h1>-->
<!--                        <field name="reference" readonly="1"/>-->
<!--                    </h1>-->
<!--                </div>-->
<!--            </xpath>-->

            <xpath expr="//label[@for='phone']" position="before">
                <label for="whatsapp_num" class="oe_inline"/>
                <div>
                    <field name="whatsapp_num"/>
                </div>
            </xpath>
            <xpath expr="//button[@name='action_schedule_meeting']" position="replace"/>
            <xpath expr="//button[@name='%(crm.crm_lead_lost_action)d']" position="replace"/>



            <xpath expr="//label[@for='date_deadline']" position="replace"/>
            <xpath expr="//field[@name='date_deadline']" position="replace"/>

                <!-- Hide Expected Revenue Block -->
            <xpath expr="//div[.//field[@name='expected_revenue']]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Probability Block -->
            <xpath expr="//div[@id='probability']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//notebook/page[last()]" position="after">
                <page name="custom_fields" string="Wheat Fields" groups="cno_hs_custom.group_wheat_menu_access">
                    <group >
                        <group string="Farmer Information" >
                            <field name="bank_name" />
                            <field name="account_title" />
                            <field name="account_number" />
                            <field name="cdr_no" />
                            <field name="cdr_status" />
                        </group>
                        <group string="Tokan Information" >
                             <field name="tokan_number" />
                             <field name="no_of_acers" />
                             <field name="bag_type" />
                            <field name="no_bags" />
                            <field name="grain_weight" />
                            <field name="tokan_date" />
                            <field name="amount" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
      </record>


      <record id="crm_case_form_view_oppor_inherit" model="ir.ui.view">
        <field name="name">crm.lead.oppor.inherited.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sale_crm.crm_case_form_view_oppor"/>
          <field name="arch" type="xml">

              <xpath expr="//button[@name='action_sale_quotations_new']" position="replace">
                  <button string="Create Purchase Order" name="action_purchase_order_new" type="object" class="oe_highlight" data-hotkey="q" title="Create Purchase Order" invisible="type == 'lead' or probability == 0 and not active"/>
              </xpath>
              <xpath expr="//button[@name='action_view_sale_order']" position="replace">
                  <button name="action_view_purchase" type="object" class="oe_stat_button"
                        icon="fa-list">
                    <field name="purchase_count" widget="statinfo" string="Purchase Order"/>
                </button>
              </xpath>
              <xpath expr="//button[@name='action_view_sale_quotation']" position="replace">
              </xpath>
          </field>
      </record>

      <record id="crm.crm_lead_action_pipeline" model="ir.actions.act_window">
            <field name="view_mode">list,kanban,graph,pivot,form,calendar,activity</field>
        </record>
      <record id="crm.crm_lead_action_pipeline_view_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="0"/>
        </record>

        <record id="crm.crm_lead_action_pipeline_view_kanban" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
        </record>


      <record id="view_crm_case_opportunities_filter_inherit" model="ir.ui.view">
          <field name="name">crm.lead.search.inherit</field>
          <field name="model">crm.lead</field>
          <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
          <field name="arch" type="xml">
              <xpath expr="//field[@name='name']" position="before">
                  <field name="tokan_number"/>
              </xpath>

              <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="filter_domain">
                        [
                            '|','|','|','|',
                            ('partner_id', 'ilike', self),
                            ('partner_name', 'ilike', self),
                            ('email_from', 'ilike', self),
                            ('contact_name', 'ilike', self),
                            ('partner_id.cnic', 'ilike', self)
                        ]
                    </attribute>
                </xpath>
          </field>
      </record>

  </data>
</odoo>