<odoo>
  <data>

      <!--CRM LEAD LIST VIEW -->
      <record id="view_crm_lead_tree_inherit" model="ir.ui.view">
          <field name="name">crm.lead.tree.inherit</field>
          <field name="model">crm.lead</field>
          <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
          <field name="arch" type="xml">
              <xpath expr="//field[@name='name']" position="before">
                  <field name="reference"/>
              </xpath>

          </field>
      </record>


      <!--CRM LEAD FORM VIEW -->
      <record id="crm_lead_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[contains(@class, 'oe_button_box')]" position="after">
                <div class="oe_title">
                    <h1>
                        <field name="reference" readonly="1"/>
                    </h1>
                </div>
            </xpath>
            <xpath expr="//button[@name='action_schedule_meeting']" position="replace"/>
            <xpath expr="//button[@name='%(crm.crm_lead_lost_action)d']" position="replace"/>



            <xpath expr="//label[@for='date_deadline']" position="replace"/>
            <xpath expr="//field[@name='date_deadline']" position="replace"/>

                <!-- Hide Expected Revenue Block -->
            <xpath expr="//div[.//field[@name='expected_revenue']]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Probability Block -->
            <xpath expr="//div[@id='probability']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//notebook/page[last()]" position="after">
                <page name="custom_fields" string="Custom Fields">
                    <group >
                        <group string="Farmer Information" >
                            <field name="bank_name" />
                            <field name="account_title" />
                            <field name="account_number" />
                            <field name="sms_text" />
                            <field name="cdr_no" />
                            <field name="cdr_status" />
                        </group>
                        <group string="Tokan Information" >
                             <field name="bag_type" />
                            <field name="no_bags" />
                            <field name="tokan_date" />
                            <field name="amount" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
      </record>


      <record id="crm_case_form_view_oppor_inherit" model="ir.ui.view">
        <field name="name">crm.lead.oppor.inherited.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sale_crm.crm_case_form_view_oppor"/>
          <field name="arch" type="xml">

              <xpath expr="//button[@name='action_sale_quotations_new']" position="replace">
                  <button string="Purchase Order" name="action_purchase_order_new" type="object" class="oe_highlight" data-hotkey="q" title="Create Purchase Order" invisible="type == 'lead' or probability == 0 and not active"/>
              </xpath>
              <xpath expr="//button[@name='action_view_sale_order']" position="replace">
                  <button name="action_view_purchase" type="object" class="oe_stat_button"
                        icon="fa-list">
                    <field name="purchase_count" widget="statinfo" string="Purchase Order"/>
                </button>
              </xpath>
              <xpath expr="//button[@name='action_view_sale_quotation']" position="replace">
              </xpath>
          </field>
      </record>

  </data>
</odoo>