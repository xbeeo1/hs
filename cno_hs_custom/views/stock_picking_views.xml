<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_picking_form_inherit" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                 <xpath expr="//button[@name='button_validate']" position="after">
                      <button string="Create Lab Request" name="action_lab_request_new" type="object" invisible="state != 'assigned' or picking_type_code != 'incoming'" class="oe_highlight" data-hotkey="q"/>
                      <button string="Unloading" name="action_unloading" type="object" invisible="state != 'assigned'" class="oe_highlight" data-hotkey="q"/>
                  </xpath>
                <xpath expr="(//button[@name='button_validate'])[1]" position="attributes">
                    <attribute name="invisible">
                        state != 'unloading'
                    </attribute>
                </xpath>
                <xpath expr='(//field[@name="state"])[1]' position="attributes">
                    <attribute name="statusbar_visible">
                        draft,assigned,unloading,done
                    </attribute>
                </xpath>
                <xpath expr="//button[@name='action_see_returns']" position="after">
                      <button name="action_view_lab_result" type="object" class="oe_stat_button"
                            icon="fa-list">
                        <field name="lab_request_count" widget="statinfo" string="Lab Result"/>
                    </button>
                  </xpath>
                <xpath expr="//notebook/page[last()]" position="after">
                    <page name="custom_fields" string="Wheat Fields" groups="cno_hs_custom.group_wheat_menu_access">
                        <group>
                            <group string="Farmer Information" >
                                    <field name="bank_name" />
                                    <field name="account_title" />
                                    <field name="reference" />
                                     <field name="account_number" />
                            </group>
                            <group string="Driver Information" >
                                    <field name="driver_name" />
                                    <field name="driver_ph_number" />
                                     <field name="driver_cnic" />
                                    <field name="driver_image" widget="image" options="{'preview_image': 'driver_image', 'size': [100, 100]}"/>
                                    <field name="driver_cnic_front" widget="image" options="{'preview_image': 'driver_cnic_front', 'size': [100, 100]}"/>
                                    <field name="driver_cnic_back" widget="image" options="{'preview_image': 'driver_cnic_back', 'size': [100, 100]}"/>
                            </group>
                        </group>
                        <group>
                            <group string="Vehicle Information" >
                                    <field name="vehicle_type_id" />
                                    <field name="vehicle_number" />
                                     <field name="driver_cnic" />
                                    <field name="vehicle_image" widget="image" options="{'preview_image': 'vehicle_image', 'size': [100, 100]}"/>
                            </group>
                             <group string="Weight Information" >
                                    <field name="total_bags" />
                                    <field name="first_weight" />
                                     <field name="second_weight" invisible="state != 'unloading'"/>
                                    <field name="net_weight" invisible="state != 'unloading'"/>
                            </group>
                        </group>
                        <group>
                            <group string="Entry/Material Information" >
                                    <field name="warehouse_id" domain="[('id', 'in', allowed_warehouse_ids)]" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}"/>
                                    <field name="cust_location_id" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}"/>
                                    <field name="nunber" />
<!--                                     <field name="e_number" />-->
                                    <field name="date_in" />
                                    <field name="date_out" invisible="state != 'unloading'"/>
                                    <field name="bag_type" />
                            </group>
                             <group>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>


    </data>
</odoo>
