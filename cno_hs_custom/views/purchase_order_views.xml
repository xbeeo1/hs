<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_order_view_form_inherit_hs" model="ir.ui.view">
            <field name="name">purchase.order.from.inherit.hs</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//widget[@name='purchase_file_uploader']" position="replace">
                    <button name="action_create_invoice" invisible="state != 'purchase'" string="Create Bill" type="object"/>
                </xpath>

                <xpath expr="//button[@name='action_purchase_comparison']" position="replace"/>


                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="whatsapp_num" />
                </xpath>

                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="per_maund" />
                </xpath>


                <xpath expr="//notebook/page[@name='purchase_delivery_invoice']" position="after">
                    <page name="custom_fields" string="Wheat Fields" groups="cno_hs_custom.group_wheat_menu_access">
                        <group string="Farmer Information" >
                            <group>
                                <field name="bank_name_id" />
                                <field name="account_title" />
                                <field name="reference" />

                            </group>
                            <group>
                                 <field name="account_number" />
                                <field name="crm_lead_id" invisible="1"/>
                            </group>
                        </group>
                    </page>
                </xpath>

                <xpath expr="//field[@name='order_line']/list//field[@name='product_id']" position="attributes">
                    <attribute name="domain">
                        [('categ_id', 'in', allowed_category_ids)]
                    </attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/list//field[@name='product_uom_id']" position="after">
                    <field name="conversion_value" readonly="1"/>
                    <field name="conversion_uom_id" readonly="1"/>
                </xpath>
            </field>
        </record>


        <record id="purchase_order_stock_view_form_inherit_hs" model="ir.ui.view">
            <field name="name">purchase.order.stock.from.inherit.hs</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase_stock.purchase_order_view_form_inherit"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_view_picking']" position="attributes">
                    <attribute name="invisible">is_shipped or state != 'purchase' or incoming_picking_count == 0 or not receipt_button_visible</attribute>
                </xpath>
                <xpath expr="//div[hasclass('oe_button_box')]/button[@name='action_view_picking']" position="attributes">
                        <attribute name="invisible">incoming_picking_count == 0 or not receipt_button_visible</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
