<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_inherit" model="ir.ui.view" >
        <field name="name">account.invoice.form.amount</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_id']" position="attributes">
                <attribute name="domain">
                        [('categ_id', 'in', allowed_category_ids)]
                    </attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_uom_id']" position="after">
                <field name="conversion_value" readonly="1"/>
                <field name="conversion_uom_id" readonly="1"/>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='account_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

        </field>
    </record>

</odoo>