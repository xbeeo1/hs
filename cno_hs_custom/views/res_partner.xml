<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='vat']" position="after">
                <field name="whatsapp_num" />
                <field name="farmer_ref" placeholder="Reference...."/>
                <field name="is_farmer" />
                <field name="is_doctor" />
                <field name="cnic" placeholder="CNIC"/>
                <field name="cnic_expiry_date" />
                <field name="date_of_birth" />
            </xpath>
            <xpath expr="//field[@name='city']" position="before">
                <field name="village_id" placeholder="Village" required="1"/>
                <div class="o_address_format">
                    <field name="division" placeholder="Division" class="o_address_city"/>
                    <field name="district" placeholder="District" class="o_address_state"/>
                    <field name="tehsil" placeholder="Tehsil" class="o_address_zip"/>
                </div>
            </xpath>

        </field>
    </record>




</odoo>