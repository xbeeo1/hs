<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="farmer_sequence_no" model="ir.sequence">
            <field name="name">Farmer Sequance Number</field>
            <field name="code">farmer.seq.no</field>
            <field name="prefix">HS-</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_crm_lead" model="ir.sequence">
            <field name="name">Crm Lead Sequence</field>
            <field name="code">crm.lead</field>
            <field name="prefix">HSKG-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>