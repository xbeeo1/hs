<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="medical_test_type_tree_view" model="ir.ui.view">
            <field name="name">medical.test.type.tree.view</field>
            <field name="model">medical.test_type</field>
            <field name="arch" type="xml">
                <list string="Lab test type">
                    <field name="name" />
                    <field name="code" />
                </list>
            </field>
        </record>
 
        <record id="medical_test_type_form_view" model="ir.ui.view">
            <field name="name">medical.test.type.form.view</field>
            <field name="model">medical.test_type</field>
            <field name="arch" type="xml">
                <form string="Lab Test">
                    <sheet>
                        <notebook>
                            <page string="Main Info">

                                <group>
                                    <field name="name" required="1" />
                                    <field name="code" />
                                    <field name="type" />
                                    <field name="auto_per_calculation" invisible = "type != 'lab_analysis'" />

                                </group>

                                <field name="critearea_ids" nolabel="1" widget="section_and_note_one2many" invisible="type != 'lab_analysis'">
                                    <list  editable="bottom" string="lab Analysis" >
                                        <field name="seq" />
                                        <field name="name" />
                                        <field name="normal_range" />
                                        <field name="limit_int" />
                                    </list>
                                    <form string="Test Cases">
                                        <field name="seq" />
                                        <field name="name" />
                                        <field name="normal_range" />
                                        <field name="limit_int" />
                                    </form>

                                </field>

                                <field name="critearea_ids" nolabel="1"
                                       widget="section_and_note_one2many"
                                       invisible="type != 'random_quality_test'">

                                    <list editable="bottom" string="Random Quality Test">
                                        <field name="seq" />
                                        <field name="bag_dhang"/>
                                        <field name="no_of_bag_drawn"/>
                                        <field name="weight_1"/>
                                        <field name="weight_2"/>
                                        <field name="weight_3"/>
                                        <field name="weight_4"/>
                                        <field name="avg_weight"/>
                                        <field name="moisture_per"/>
                                        <field name="trash_statust"/>

                                    </list>

                                </field>

                                <group>
                                    <field name="service_product_id" />
                                </group>
                            </page>
                            <page string="Extra Info">
                                <field name="info" />
                            </page>
                        </notebook>
                    </sheet>
                </form>

            </field>
        </record>

        <record id="action_medical_test_type" model="ir.actions.act_window">
            <field name="name">Lab Test Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">medical.test_type</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Lab Test Type" id="menu_lab_new_type_lab_test"
            parent="main_menu_conf_laboratory" action="action_medical_test_type" />

</odoo>
