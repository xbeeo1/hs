<odoo>
    <data>


        <record id="product_template_only_form_view_inherit" model="ir.ui.view">
            <field name="name">product.template.only.form.inherit.emc</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//notebook/page[last()]" position="after">
                    <page name="custom_fields" string="Custom Fields">
                        <group>
                            <group string="For Lab test">
                                <field name="create_mrp_order" />
                                <field name="done_mrp_order" />
                            </group>
                            <group>
                                <group string="For Custom Receipt">
                                    <field name="is_custom" />
                                </group>
                                <group string="For Stock Report">
                                    <field name="bardana_weight" />
                                    <field name="filled_bardana_weight" />
                                </group>
                            </group>
                        </group>
                        <group>
                            <group string="UOM Conversion">
                                <field name="conversion_value" />
                                <field name="conversion_uom_id" />
                            </group>
                            <group string="Allow Negative Price">
                                <field name="is_price_negative" />
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>