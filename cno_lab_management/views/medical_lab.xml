<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="medical_lab_tree_view" model="ir.ui.view">
            <field name="name">medical.lab.tree.view</field>
            <field name="model">medical.lab</field>
            <field name="arch" type="xml">
                <list create="false" >
                    <field name="name" />
                    <field name="test_id" />
                    <field name="patient_id" />
                    <field name="date_analysis" />
                </list>
            </field>
        </record>



        <record id="medical_lab_form_view" model="ir.ui.view">
            <field name="name">medical.lab.form.view</field>
            <field name="model">medical.lab</field>
            <field name="arch" type="xml">
                <form string="Laboratory Test" create="false">
                    <sheet>
                        <header>
                            <button name="action_approved" class="oe_highlight" invisible="state != 'draft'" string="Approved" type="object"/>
                            <button name="action_rejected" class="oe_highlight" invisible="state != 'draft'" string="Rejected" type="object"/>
                            <button name="action_cancelled" class="oe_highlight" invisible="state != 'approved'" string="Cancelled" type="object"/>

                            <field name="state" widget="statusbar"/>
                        </header>

                        <group string="Main Info">
                            <group>
                                <field name="name" readonly="1" />
                                <field name="date_analysis" />
                                <field name="requestor_physician_id"
                                    required="1" />
                                <field name="gate_pass_no" />
                                <field name="vehicle_number" />
                                <field name="bag_type" />
                            </group>
                            <group>
                                <field name="test_id" required="1" />
                                <field name="patient_id" required="1" />
                                <field name="date_requested" />
                                <field name="tokan_no" />
                                <field name="sample_weight_gram" invisible="type != 'lab_analysis'"/>
                                <field name="standard_bag_weight" invisible="type != 'random_quality_test'"/>
                                <field name="type" invisible = '1'/>
                            </group>
                        </group>
                        <notebook> 
                            <page string = "Total Cases">  
                                <field name="critearea_ids" widget="section_and_note_one2many" invisible="type != 'lab_analysis'" readonly="state != 'draft'" nolabel="1">
                                    <list editable="top" string="Test Cases" decoration-danger="is_below_limit">
                                        <field name="seq" readonly="1"/>
                                        <field name="name" readonly="1"/>
                                        <field name="normal_range"  readonly="1"/>
                                        <field name="gram" />
                                        <field name="percentage" />
                                        <field name="is_below_limit" column_invisible="True" />
                                    </list>

                                    <form string="Test Cases">

                                        <field name="name" />
                                        <field name="seq" />
                                        <field name="normal_range" />
                                        <field name="gram" />
                                        <field name="percentage" />
                                    </form>
                                </field>
                                <field name="critearea_ids" nolabel="1"
                                       widget="section_and_note_one2many"
                                       invisible="type != 'random_quality_test'" readonly="state != 'draft'">

                                    <list editable="bottom" string="Random Quality Test" decoration-danger="is_avg_weight">
                                        <field name="seq" />
                                        <field name="bag_dhang"/>
                                        <field name="no_of_bag_drawn"/>
                                        <field name="weight_1"/>
                                        <field name="weight_2"/>
                                        <field name="weight_3"/>
                                        <field name="weight_4"/>
                                        <field name="avg_weight"/>
                                        <field name="moisture_per"/>
                                        <field name="trash_statust"/>
                                        <field name="is_avg_weight" column_invisible="True"/>


                                    </list>

                                </field>

                            </page>
                        </notebook>

                        <group string="Extra Info">
                            <field name="results" />
                            <field name="diagnosis" />
                        </group>
                    </sheet>
                </form>

            </field>
        </record>

        <record id="action_medical_lab_form" model="ir.actions.act_window">
            <field name="name">Lab Tests Results</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">medical.lab</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_medical_lab_tree" model="ir.actions.act_window">
            <field name="name">Lab Tests Results</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">medical.lab</field>
            <field name="binding_view_types">list</field>
            <field name="view_mode">list</field>
        </record>

    <record id="action_view_lab_id" model="ir.actions.act_window">
        <field name="name">Lab Reports</field>
        <field name="res_model">medical.lab</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="domain">[('patient_id', '=', active_id)]</field>
    </record>

        <menuitem name="Lab Tests Results" id="menu_lab_test_result"
            parent="cno_lab_management.main_menu_laboratory" action="action_medical_lab_form"
            sequence="0" />

</odoo>
